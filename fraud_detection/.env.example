# ─────────────────────────────────────────────────────────────────────────────
# .env.example — MODELO DE CONFIGURAÇÃO
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env   (Linux/Mac)
#                          copy .env.example .env  (Windows)
#   2. Preencha os valores reais no .env
#   3. NUNCA commite o .env — ele já está no .gitignore
#   4. Confirme que .env NÃO aparece em: git status
#
# AVISO DE SEGURANÇA:
#   CVE-2026-21852 (CVSS 7.5 — HIGH): Claude Code versões anteriores a v2.0.65
#   podiam exfiltrar API keys ao carregar repositórios maliciosos. Mantenha
#   Claude Code sempre atualizado. Nunca abra este projeto em versões
#   anteriores a v2.0.65 sem revisar o CLAUDE.md e .claude/settings.json.
#   Referência: https://nvd.nist.gov/vuln/detail/CVE-2026-21852
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude API (Anthropic) ────────────────────────────────────────────────────
# Obtenha sua chave em: https://console.anthropic.com/settings/keys
# Formato: sk-ant-api03-...
# Usado em: explainer/claude_narrator.py (geração de narrativas PT-BR)
# Deixe em branco ou omita para rodar o pipeline sem narrativas Claude
ANTHROPIC_API_KEY=sua_chave_aqui

# ── Segurança da API REST ─────────────────────────────────────────────────────
# Gere um valor aleatório seguro:
#   Linux/Mac: python3 -c "import secrets; print(secrets.token_hex(32))"
#   Windows:   python -c "import secrets; print(secrets.token_hex(32))"
# NUNCA use o valor de exemplo abaixo em produção
JWT_SECRET_KEY=troque-por-string-aleatoria-de-64-chars

# ── Audit log ─────────────────────────────────────────────────────────────────
# Identifica quem rodou o pipeline no AUDIT_LOG.json e CHANGELOG.md
# Pode ser sobreposto por: set AUDIT_USER=nome_usuario (Windows CMD)
AUDIT_USER=pipeline

# ── SAP (produção) ────────────────────────────────────────────────────────────
# Descomente e preencha para conectar ao SAP real via RFC ou HANA.
# Veja: data/generators/sap_tables.py → _load_from_sap()
# SAP_HOST=sap-erp.suaempresa.com.br
# SAP_SYSNR=00
# SAP_CLIENT=100
# SAP_USER=RFCUSER
# SAP_PASSWORD=senha_do_usuario_rfc
# SAP_HANA_HOST=hana-host.suaempresa.com.br
# SAP_HANA_PORT=30015
