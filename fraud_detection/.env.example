# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-...

# JWT signing secret — use a random 64-char string in production
JWT_SECRET_KEY=change-this-to-a-long-random-string

# Pipeline user for audit log
AUDIT_USER=pipeline

# Optional: point to real SAP RFC connection
# SAP_HOST=sap-host.internal
# SAP_SYSNR=00
# SAP_CLIENT=100
# SAP_USER=rfcuser
# SAP_PASSWORD=rfcpassword
