# ─────────────────────────────────────────────────────────────────────────────
# SEGREDOS E CREDENCIAIS — nunca devem entrar no repositório
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example          # .env.example é seguro — sem valores reais
*.key
*.pem
*.pfx
*.p12
*.crt
*.cer
*secret*
*credential*
*password*
*apikey*
*api_key*
*token*
!governance/checksums.json   # exceção — não é segredo

# Claude Code settings (pode conter hooks com chaves inline)
.claude/settings.local.json

# ─────────────────────────────────────────────────────────────────────────────
# DADOS GERADOS PELO PIPELINE — grandes demais ou regeneráveis
# ─────────────────────────────────────────────────────────────────────────────
data/raw/
data/processed/

# ─────────────────────────────────────────────────────────────────────────────
